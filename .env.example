# Environment Variables Template
# Copy this to .env and fill in your actual values

# === MongoDB Configuration ===
# For local development:
MONGODB_URI=mongodb://localhost:27017

# For Heroku (MongoDB Atlas):
# MONGODB_URI=mongodb+srv://megallm_user:PASSWORD@cluster-name.mongodb.net/megallm_blog_platform?retryWrites=true&w=majority

MONGODB_DB=megallm_blog_platform

# === LLM API Configuration ===
# Using OpenRouter (FREE tier)
USE_OPENROUTER=true
OPENROUTER_API_KEY=sk-or-v1-YOUR_OPENROUTER_KEY_HERE
OPENROUTER_MODEL=qwen/qwen3.6-plus-preview:free

# Alternative: Using MegaLLM (if you have key)
# USE_OPENROUTER=false
# MEGALLM_API_KEY=sk-mega-YOUR_MEGALLM_KEY_HERE

# === Flask Configuration ===
FLASK_ENV=development
# For production: FLASK_ENV=production

# === Feature Flags ===
# Enable/disable OpenRouter vs MegaLLM
USE_OPENROUTER=true

# === API Keys Notes ===
# 1. OpenRouter API Key:
#    - Get from: https://openrouter.ai/keys
#    - Starts with: sk-or-v1-
#    - Model: qwen/qwen3.6-plus-preview:free (free tier)
#
# 2. MongoDB Atlas Connection:
#    - Create at: https://mongodb.com/cloud/atlas
#    - Format: mongodb+srv://username:password@cluster.mongodb.net/dbname
#    - Make sure to allow 0.0.0.0/0 in Network Access
#
# 3. MegaLLM API (alternative):
#    - Get from your MegaLLM account
#    - Requires: USE_OPENROUTER=false
