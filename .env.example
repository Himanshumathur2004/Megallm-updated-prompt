# MegaLLM Blog Platform - Environment Variables
# Copy this to .env and fill in your actual values
# DO NOT commit .env file - it contains sensitive credentials

# === REQUIRED: MongoDB Atlas Configuration ===
MONGODB_URI=mongodb+srv://your_username:your_password@cluster0.xxxxx.mongodb.net/?appName=Cluster0
MONGODB_DB=megallm_blog_platform

# === REQUIRED: OpenRouter API Key ===
# Get your free API key from: https://openrouter.ai/keys
# Starts with: sk-or-v1-
OPENROUTER_API_KEY=sk-or-v1-YOUR_API_KEY_HERE

# === REQUIRED: OpenRouter Model ===
# Free model for inference
OPENROUTER_MODEL=qwen/qwen3.6-plus:free

# === OPTIONAL: Flask Configuration ===
# Set to 'production' for Render deployment
FLASK_ENV=production
DEBUG=False
