# MegaLLM Blog Generation Platform Configuration
# Copy this to .env and fill in your actual values

# ============================================================================
# LLM API Configuration (Choose MegaLLM or OpenRouter)
# ============================================================================

# Enable OpenRouter (set to false to use MegaLLM instead)
USE_OPENROUTER=true

# OpenRouter API Key (https://openrouter.io/keys) - Required if USE_OPENROUTER=true
OPENROUTER_API_KEY=your_openrouter_api_key_here

# OpenRouter Model to use (default: meta-llama/llama-3-8b-instruct - free model)
# Free models: meta-llama/llama-3-8b-instruct, mistral/mistral-7b, gpt2
OPENROUTER_MODEL=meta-llama/llama-3-8b-instruct

# MegaLLM API Key (fallback if USE_OPENROUTER=false)
MEGALLM_API_KEY=sk-mega-YOUR_KEY_HERE

# Fallback if MEGALLM_API_KEY not set
OPENAI_API_KEY=sk-mega-YOUR_KEY_HERE

# MegaLLM Model to use (default: deepseek-ai/deepseek-v3.1)
MEGALLM_MODEL=deepseek-ai/deepseek-v3.1

# ============================================================================
# MongoDB Configuration
# ============================================================================

# MongoDB connection URI
MONGODB_URI=mongodb://localhost:27017

# MongoDB database name
MONGODB_DB=megallm_blog_platform

# ============================================================================
# Flask Configuration
# ============================================================================

# Flask environment (development or production)
FLASK_ENV=development

# Enable debug mode (set to False in production)
DEBUG=True

# Secret key for sessions (change this in production!)
SECRET_KEY=dev-secret-key-change-in-production

# ============================================================================
# Blog Generation Settings (Optional)
# ============================================================================

# Blog word count minimum (default: 500)
# BLOG_WORD_COUNT_MIN=500

# Blog word count maximum (default: 800)
# BLOG_WORD_COUNT_MAX=800

# Blog generation temperature (default: 0.65)
# BLOG_TEMPERATURE=0.65

# Generation interval in minutes (default: 120 = every 2 hours)
# GENERATION_INTERVAL_MINUTES=120
